# Base de datos PostgreSQL (Railway: copiar DATABASE_URL del servicio Postgres)
DATABASE_URL="postgresql://usuario:password@host.proxy.rlwy.net:PUERTO/railway"

# Secreto para NextAuth (generar con: openssl rand -base64 32)
NEXTAUTH_SECRET="reemplazar-con-secreto-seguro-de-32-chars"

# URL del sitio en produccion (dominio principal Cláriva)
NEXTAUTH_URL="https://app.clariva.cl"

# Solo para el script de seed inicial (no se usa en produccion)
SEED_ADMIN_EMAIL="admin@digitaldent.cl"
SEED_ADMIN_PASSWORD="cambiar-por-password-seguro"
