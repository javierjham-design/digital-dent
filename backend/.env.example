# Backend de Cláriva — variables de entorno
# La base de datos es la MISMA que el monolito durante la migración.
DATABASE_URL=postgresql://user:pass@host:5432/clariva

# Secreto para firmar los JWT que emite el backend. En producción usar uno
# fuerte y distinto del de NextAuth (o reusar NEXTAUTH_SECRET para transición).
JWT_SECRET=
JWT_EXPIRES_IN=12h

# Orígenes del frontend permitidos por CORS (separados por coma).
CORS_ORIGINS=http://localhost:5173

PORT=4000
NODE_ENV=development

# Reusadas del monolito (mismas claves) para integraciones.
ENCRYPTION_KEY=
CRON_SECRET=
