# Backend de Cláriva — variables de entorno
# ───────────────────────────────────────────────────────────────────────────

# Base de datos. Es la MISMA que usa el monolito (single source of truth).
# En el cutover, el backend apunta a la DATABASE_URL de Postgres de Railway.
DATABASE_URL=postgresql://user:pass@host:5432/clariva

# Secreto para firmar los JWT que emite el backend.
# IMPORTANTE: para que las sesiones del monolito y del backend sean
# intercambiables durante la transición, reutilizar el MISMO valor que
# NEXTAUTH_SECRET del monolito. (El backend cae a NEXTAUTH_SECRET si no se define.)
JWT_SECRET=
JWT_EXPIRES_IN=12h

# Orígenes del frontend permitidos por CORS (separados por coma, sin slash final).
# Producción: la URL pública del servicio frontend (p.ej. https://app.clariva.cl).
CORS_ORIGINS=http://localhost:5173

PORT=4000
NODE_ENV=development

# Clave de cifrado AES-256-GCM (tokens de Twilio, refresh tokens de Google).
# DEBE ser EXACTAMENTE la misma que usa el monolito, o no se podrán descifrar
# los secretos ya guardados en la base.
ENCRYPTION_KEY=

# Secreto para el endpoint de sync de Google por cron (POST /google/sync).
CRON_SECRET=

# Google Calendar (opcional; solo si se usa la integración). El redirect URI
# debe apuntar al backend y estar registrado en Google Cloud Console:
#   https://<dominio-backend>/api/v1/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
