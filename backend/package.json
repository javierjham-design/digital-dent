{
  "name": "@clariva/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "API backend de Cláriva (Express + Prisma). Lógica de negocio, auth y multi-tenant.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prestart": "npm run control:push && npm run migrate:tenants",
    "start": "tsx src/index.ts",
    "build": "npm run prisma:generate:all",
    "postinstall": "npm run prisma:generate:all",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:contract": "node ../scripts/contract-check.mjs",
    "smoke:deploy": "node ../scripts/smoke-deploy.mjs",
    "prisma:generate:control": "prisma generate --schema prisma/control/schema.prisma",
    "prisma:generate:tenant": "prisma generate --schema prisma/tenant/schema.prisma",
    "prisma:generate:all": "npm run prisma:generate:control && npm run prisma:generate:tenant",
    "control:push": "prisma db push --schema prisma/control/schema.prisma",
    "tenant:initsql": "prisma migrate diff --from-empty --to-schema-datamodel prisma/tenant/schema.prisma --script > prisma/tenant/init.sql",
    "migrate:tenants": "tsx src/scripts/migrate-tenants.ts",
    "prisma:generate:legacy": "node prisma/legacy/build-schema.mjs && prisma generate --schema prisma/legacy/schema.prisma",
    "migrate:data": "tsx src/scripts/migrate-data.ts",
    "dedupe:prestaciones": "tsx src/scripts/dedupe-prestaciones.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "xlsx": "^0.18.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
