// ─────────────────────────────────────────────────────────────────────────────
//  TENANT (1 base de datos por clínica — aislamiento físico)
//  Contiene TODOS los datos operativos de una clínica: equipo, pacientes,
//  agenda, fichas clínicas, presupuestos, cobros, caja, liquidaciones y su
//  configuración/integraciones. Como cada base ES una clínica, los modelos NO
//  llevan clinicaId. El backend abre la base correcta según el subdominio.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output   = "../generated/tenant"
}

datasource db {
  provider = "postgresql"
  // URL dinámica: en runtime se pasa la de cada clínica; este env es solo para
  // los comandos de Prisma CLI (generate / db push sobre una base concreta).
  url      = env("TENANT_DATABASE_URL")
}

// Perfil + integraciones de la clínica (singleton por base).
model Configuracion {
  id        String  @id @default("singleton")
  nombre    String  @default("Mi clínica")
  rut       String?
  direccion String  @default("")
  ciudad    String  @default("Temuco")
  telefono  String  @default("")
  email     String  @default("")
  logoUrl   String?
  mensajeWA String  @default("Hola {nombre}, te escribimos de *{clinica}* para confirmar tu cita el {fecha} en {direccion}.")

  // WhatsApp (Twilio). El auth token va cifrado (AES-256-GCM).
  waEnabled     Boolean @default(false)
  waTwilioSid   String?
  waTwilioToken String?
  waNumero      String?
  waTemplateSid String?
  waHorasAntes  Int     @default(24)

  // Google Calendar (una cuenta por clínica). Tokens cifrados.
  googleRefreshToken    String?
  googleAccessToken     String?
  googleTokenExpiresAt  DateTime?
  googleAccountEmail    String?
  googleConnectedAt     DateTime?
  googleConnectedById   String?
  googleConnectedByName String?

  // Marketing / Meta (CRM). Pixel ID es público (se inyecta en el navegador);
  // el token de Conversions API es secreto (server-side). crmToken autentica el
  // endpoint público de captación de formularios web.
  metaEnabled   Boolean @default(false)
  metaPixelId   String?
  metaCapiToken String?
  metaTestCode  String?
  crmToken      String?

  updatedAt DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  username      String?   @unique
  password      String
  role          String    @default("staff") // admin | doctor | staff
  rut           String?   @unique
  especialidad  String?
  telefono      String?
  activo        Boolean   @default(true)
  passwordChangedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  puedeRecibirPagos           Boolean @default(false)
  puedeModificarPrecio        Boolean @default(false)
  puedeAplicarDescuento       Boolean @default(false)
  puedeRevertirCompletado     Boolean @default(false)
  puedeEditarPagos            Boolean @default(false)
  puedeGestionarLiquidaciones Boolean @default(false)

  // Mapeo a un calendario de Google (dentro de la cuenta de la clínica).
  googleCalendarId String?
  googleSyncToken  String?
  googleSyncedAt   DateTime?

  citas              Cita[]            @relation("DoctorCitas")
  tratamientos       Tratamiento[]     @relation("DoctorTratamientos")
  contratos          Contrato[]
  liquidaciones      Liquidacion[]
  horarios           HorarioDoctor[]
  cobrosRecibidos    Cobro[]           @relation("CobroUsuario")
  evolucionesCreadas Evolucion[]       @relation("AutorEvolucion")
  planesTitulares    PlanTratamiento[] @relation("DoctorTitularPlanes")
  cajas              CajaUsuario[]
  movimientosCaja    MovimientoCaja[]  @relation("MovimientoUsuario")
  bloqueosAgenda     BloqueoAgenda[]   @relation("DoctorBloqueos")
  linksAgenda        LinkAgenda[]
  linksAgendaProf    LinkAgendaProfesional[]
}

model Paciente {
  id               String    @id @default(cuid())
  numero           Int?      @unique
  rut              String?   @unique
  otroDocId        String?
  nombre           String
  apellido         String
  nombreSocial     String?
  fechaNacimiento  DateTime?
  genero           String?
  sexo             String?
  nacionalidad     String?
  migrante         String?
  puebloOriginario String?
  telefono         String?
  telefonoFijo     String?
  email            String?
  direccion        String?
  ciudad           String?
  comuna           String?
  prevision        String?
  actividad        String?
  empleador        String?
  apoderado        String?
  rutApoderado     String?
  referencia       String?
  tipoPaciente     String?
  numeroInterno    String?
  alergias         String?
  antecedentes     String?
  observaciones    String?
  contactoEmergencia String?
  telefonoEmergencia String?
  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  citas            Cita[]
  fichaClinica     FichaClinica?
  presupuestos     Presupuesto[]
  planes           PlanTratamiento[]
  evoluciones      Evolucion[]
  cobros           Cobro[]
  comentariosAdmin ComentarioAdministrativo[]
  mensajes         MensajePaciente[]
}

model ComentarioAdministrativo {
  id          String   @id @default(cuid())
  pacienteId  String
  autorNombre String
  autorId     String?
  texto       String
  createdAt   DateTime @default(now())
  paciente    Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
}

model MensajePaciente {
  id         String   @id @default(cuid())
  pacienteId String
  citaId     String?
  tipo       String
  categoria  String
  asunto     String?
  cuerpo     String?
  enviadoA   String?
  estado     String   @default("ENVIADO")
  createdAt  DateTime @default(now())
  paciente   Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  cita       Cita?    @relation(fields: [citaId], references: [id])
}

model Cita {
  id           String   @id @default(cuid())
  pacienteId   String
  doctorId     String
  fecha        DateTime
  duracion     Int      @default(30)
  estado       String   @default("PENDIENTE")
  tipo         String?
  notas        String?
  sala         String?
  sobrecupo    Boolean  @default(false)
  confirmadoWA Boolean  @default(false)
  origen       String?  // null = interna; "ONLINE" = reserva pública del paciente
  linkAgendaId String?  // link de agendamiento online que la generó
  googleEventId   String?
  googleSyncedAt  DateTime?
  googleSyncError String?
  waMessageSid    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  paciente     Paciente @relation(fields: [pacienteId], references: [id])
  doctor       User     @relation("DoctorCitas", fields: [doctorId], references: [id])
  logs         CitaLog[]
  mensajes     MensajePaciente[]

  @@index([googleEventId])
  @@index([waMessageSid])
  @@index([doctorId, fecha])
}

model CitaLog {
  id        String   @id @default(cuid())
  citaId    String
  tipo      String
  detalle   String
  userName  String   @default("Sistema")
  createdAt DateTime @default(now())
  cita      Cita     @relation(fields: [citaId], references: [id], onDelete: Cascade)
}

model FichaClinica {
  id                String        @id @default(cuid())
  pacienteId        String        @unique
  grupoSanguineo    String?
  fumador           Boolean       @default(false)
  embarazada        Boolean       @default(false)
  diabetico         Boolean       @default(false)
  hipertenso        Boolean       @default(false)
  cardiopatia       Boolean       @default(false)
  medicamentos      String?
  notasClinicas     String?
  alertasMedicas    String?
  enfermedadesNotas String?
  motivoAtencion    String?
  impresionMedica   String?
  resumenDiagnostico String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  paciente          Paciente      @relation(fields: [pacienteId], references: [id])
  tratamientos      Tratamiento[]
  odontograma       Diente[]
}

model Diente {
  id     String       @id @default(cuid())
  fichaId String
  numero Int
  cara   String?
  estado String       @default("SANO")
  color  String?
  notas  String?
  ficha  FichaClinica @relation(fields: [fichaId], references: [id])

  @@unique([fichaId, numero, cara])
}

model Prestacion {
  id               String            @id @default(cuid())
  nombre           String
  descripcion      String?
  precio           Float
  duracion         Int               @default(30)
  categoria        String?
  activo           Boolean           @default(true)
  tratamientos     Tratamiento[]
  itemsPresupuesto ItemPresupuesto[]
}

model Tratamiento {
  id              String           @id @default(cuid())
  fichaId         String
  planId          String?
  seccionId       String?
  prestacionId    String
  doctorId        String?
  diente          Int?
  cara            String?
  estado          String           @default("PLANIFICADO")
  precio          Float
  descuento       Float            @default(0)
  notas           String?
  fecha           DateTime         @default(now())
  fechaCompletado DateTime?
  ficha           FichaClinica     @relation(fields: [fichaId], references: [id])
  plan            PlanTratamiento? @relation(fields: [planId], references: [id], onDelete: SetNull)
  seccion         SeccionPlan?     @relation(fields: [seccionId], references: [id], onDelete: SetNull)
  prestacion      Prestacion       @relation(fields: [prestacionId], references: [id])
  doctor          User?            @relation("DoctorTratamientos", fields: [doctorId], references: [id])
  liquidacionItems LiquidacionItem[]
  cobroItems      CobroItem[]
  evoluciones     Evolucion[]
}

model PlanTratamiento {
  id              String        @id @default(cuid())
  pacienteId      String
  doctorTitularId String?
  nombre          String        @default("Plan de tratamiento")
  estado          String        @default("ACTIVO")
  bloqueado       Boolean       @default(false)  // bloqueo al imprimir; desbloquear para editar
  notas           String?
  fechaInicio     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paciente        Paciente      @relation(fields: [pacienteId], references: [id])
  doctorTitular   User?         @relation("DoctorTitularPlanes", fields: [doctorTitularId], references: [id])
  secciones       SeccionPlan[]
  tratamientos    Tratamiento[]
}

model SeccionPlan {
  id                String          @id @default(cuid())
  planId            String
  titulo            String          @default("Sección")
  orden             Int             @default(0)
  fechaTentativa    DateTime?
  diasDesdeAnterior Int?
  notas             String?
  plan              PlanTratamiento @relation(fields: [planId], references: [id], onDelete: Cascade)
  tratamientos      Tratamiento[]
}

model Evolucion {
  id            String       @id @default(cuid())
  pacienteId    String
  tratamientoId String?
  autorId       String?
  texto         String
  fecha         DateTime     @default(now()) // fecha clínica de la evolución (editable)
  createdAt     DateTime     @default(now())
  paciente      Paciente     @relation(fields: [pacienteId], references: [id])
  tratamiento   Tratamiento? @relation(fields: [tratamientoId], references: [id], onDelete: SetNull)
  autor         User?        @relation("AutorEvolucion", fields: [autorId], references: [id])
}

// Bitácora de auditoría: registro inmutable de quién hizo qué y cuándo sobre los
// datos clínicos del paciente. Requisito legal de trazabilidad de la ficha
// clínica (Ley 20.584 / Ley 21.719). No se edita ni se borra desde la app.
model AuditLog {
  id           String   @id @default(cuid())
  fecha        DateTime @default(now())
  userId       String?
  userNombre   String?
  accion       String   // CREAR | EDITAR | EVOLUCIONAR | ELIMINAR
  entidad      String   // Paciente | FichaClinica | Evolucion | Tratamiento | PlanTratamiento | Cobro
  entidadId    String?
  pacienteId   String?
  resumen      String
  datosPrevios String?  // estado anterior (JSON) en ediciones/borrados

  @@index([pacienteId, fecha])
}

model Presupuesto {
  id         String            @id @default(cuid())
  pacienteId String
  numero     Int               @unique
  estado     String            @default("PENDIENTE")
  total      Float             @default(0)
  notas      String?
  vigencia   DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  paciente   Paciente          @relation(fields: [pacienteId], references: [id])
  items      ItemPresupuesto[]
}

model ItemPresupuesto {
  id             String      @id @default(cuid())
  presupuestoId  String
  prestacionId   String
  diente         Int?
  cantidad       Int         @default(1)
  precioUnitario Float
  descuento      Float       @default(0)
  subtotal       Float
  presupuesto    Presupuesto @relation(fields: [presupuestoId], references: [id])
  prestacion     Prestacion  @relation(fields: [prestacionId], references: [id])
}

model MedioPago {
  id                 String  @id @default(cuid())
  nombre             String
  comision           Float   @default(0)
  activo             Boolean @default(true)
  requiereReferencia Boolean @default(false) // pagos con tarjeta exigen N° de operación
  cobros             Cobro[]
}

model Cobro {
  id               String     @id @default(cuid())
  pacienteId       String
  numero           Int        @unique
  concepto         String
  monto            Float
  montoNeto        Float?
  comisionMonto    Float?
  estado           String     @default("PENDIENTE")
  medioPagoId      String?
  metodoPago       String?
  reciboUsuarioId  String?
  cajaId           String?
  fechaPago        DateTime?
  notas            String?
  numeroReferencia String?    // N° de operación (obligatorio en pagos con tarjeta)
  numeroBoleta     String?    // N° de boleta (opcional, cualquier pago)
  anulado          Boolean    @default(false)
  motivoAnulacion  String?
  anuladoAt        DateTime?
  anuladoPorId     String?
  anuladoPorNombre String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  paciente         Paciente   @relation(fields: [pacienteId], references: [id])
  medioPago        MedioPago? @relation(fields: [medioPagoId], references: [id])
  reciboUsuario    User?      @relation("CobroUsuario", fields: [reciboUsuarioId], references: [id])
  caja             Caja?      @relation(fields: [cajaId], references: [id])
  items            CobroItem[]
  movimientos      MovimientoCaja[]
}

model Caja {
  id           String       @id @default(cuid())
  nombre       String       @unique
  descripcion  String?
  saldoInicial Float        @default(0)
  activo       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  usuarios     CajaUsuario[]
  movimientos  MovimientoCaja[]
  cobros       Cobro[]
  sesiones     SesionCaja[]
}

model SesionCaja {
  id               String    @id @default(cuid())
  cajaId           String
  estado           String    @default("ABIERTA")
  saldoApertura    Float     @default(0)
  abiertaPorId     String
  abiertaPorNombre String?
  abiertaAt        DateTime  @default(now())
  cerradaPorId     String?
  cerradaPorNombre String?
  cerradaAt        DateTime?
  saldoEsperado    Float?
  saldoReal        Float?
  diferencia       Float?
  totalIngresos    Float?
  totalEgresos     Float?
  observaciones    String?
  createdAt        DateTime  @default(now())
  caja             Caja      @relation(fields: [cajaId], references: [id])
  movimientos      MovimientoCaja[]

  @@index([cajaId, estado])
  @@index([cajaId, abiertaAt])
}

model CajaUsuario {
  cajaId String
  userId String
  caja   Caja @relation(fields: [cajaId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cajaId, userId])
}

model MovimientoCaja {
  id               String      @id @default(cuid())
  cajaId           String
  sesionCajaId     String?
  tipo             String
  monto            Float
  descripcion      String
  categoria        String?
  fecha            DateTime    @default(now())
  cobroId          String?
  userId           String
  anulado          Boolean     @default(false)
  motivoAnulacion  String?
  anuladoAt        DateTime?
  anuladoPorId     String?
  anuladoPorNombre String?
  createdAt        DateTime    @default(now())
  caja             Caja        @relation(fields: [cajaId], references: [id])
  cobro            Cobro?      @relation(fields: [cobroId], references: [id])
  user             User        @relation("MovimientoUsuario", fields: [userId], references: [id])
  sesion           SesionCaja? @relation(fields: [sesionCajaId], references: [id])

  @@index([cajaId, fecha])
  @@index([sesionCajaId])
}

model CobroItem {
  id            String       @id @default(cuid())
  cobroId       String
  tratamientoId String?
  planId        String?      // abono libre a un plan (sin acción específica)
  descripcion   String
  monto         Float
  cobro         Cobro        @relation(fields: [cobroId], references: [id], onDelete: Cascade)
  tratamiento   Tratamiento? @relation(fields: [tratamientoId], references: [id])

  @@index([planId])
}

model Contrato {
  id            String        @id @default(cuid())
  doctorId      String
  tipo          String
  porcentaje    Float?
  montoFijo     Float?
  descripcion   String?
  fechaInicio   DateTime      @default(now())
  fechaFin      DateTime?
  activo        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  doctor        User          @relation(fields: [doctorId], references: [id])
  liquidaciones Liquidacion[]
}

model Liquidacion {
  id             String            @id @default(cuid())
  doctorId       String
  contratoId     String
  periodo        String
  totalBruto     Float             @default(0)
  totalLiquidado Float             @default(0)
  estado         String            @default("BORRADOR")
  notas          String?
  fechaPago      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  doctor         User              @relation(fields: [doctorId], references: [id])
  contrato       Contrato          @relation(fields: [contratoId], references: [id])
  items          LiquidacionItem[]
  adjuntos       LiquidacionAdjunto[]
}

// Archivos asociados a una liquidación (factura del profesional, comprobante de
// transferencia). Se guardan como bytes en la base de la clínica.
model LiquidacionAdjunto {
  id              String      @id @default(cuid())
  liquidacionId   String
  tipo            String      // FACTURA | COMPROBANTE
  nombre          String      // nombre original del archivo
  mime            String
  size            Int
  data            Bytes
  subidoPorId     String?
  subidoPorNombre String?
  createdAt       DateTime    @default(now())
  liquidacion     Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)

  @@index([liquidacionId])
}

model LiquidacionItem {
  id                 String      @id @default(cuid())
  liquidacionId      String
  tratamientoId      String
  prestacionNombre   String
  pacienteNombre     String
  diente             String?
  fechaCompletado    DateTime
  precioTratamiento  Float
  porcentajeAplicado Float?
  montoFijoAplicado  Float?
  montoPagado        Float       @default(0)  // lo que el paciente pagó por la acción
  comisionAplicada   Float       @default(0)  // comisión del medio de pago descontada
  medioPago          String?                  // medio(s) de pago de la acción
  montoLiquidado     Float                    // total pagado al profesional (neto)
  liquidacion        Liquidacion @relation(fields: [liquidacionId], references: [id])
  tratamiento        Tratamiento @relation(fields: [tratamientoId], references: [id])
}

model HorarioDoctor {
  id              String  @id @default(cuid())
  doctorId        String
  diaSemana       Int
  horaInicio      String
  horaFin         String
  activo          Boolean @default(true)
  recesoActivo    Boolean @default(false)
  recesoInicio    String?
  recesoFin       String?
  sobrecupoActivo Boolean @default(false)
  sobrecupoInicio String?
  sobrecupoFin    String?
  doctor          User    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, diaSemana])
}

model BloqueoAgenda {
  id            String   @id @default(cuid())
  doctorId      String
  inicio        DateTime
  fin           DateTime
  motivo        String?
  createdById   String?
  createdByName String?
  googleEventId   String?
  googleSyncedAt  DateTime?
  googleSyncError String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  doctor        User     @relation("DoctorBloqueos", fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId, inicio])
  @@index([googleEventId])
}

// Link público de agendamiento online. Cada link reserva citas para un
// profesional, con un tipo/etiqueta y duración fijos. La disponibilidad es
// híbrida: usa el horario del profesional, o ventanas exclusivas propias.
model LinkAgenda {
  id                  String   @id @default(cuid())
  token               String   @unique          // identificador público en la URL
  nombre              String
  descripcion         String?
  doctorId            String
  tipoCita            String   @default("EVALUACION") // se guarda en Cita.tipo
  duracionMin         Int      @default(30)
  usaHorarioDoctor    Boolean  @default(true)   // false → usa solo sus ventanas
  anticipacionHoras   Int      @default(12)     // antelación mínima para reservar
  diasMaxFuturo       Int      @default(30)     // ventana de reserva hacia adelante
  mensajeConfirmacion String?
  color               String?
  activo              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  doctor              User     @relation(fields: [doctorId], references: [id])
  ventanas            LinkAgendaVentana[]
  profesionales       LinkAgendaProfesional[]

  @@index([doctorId])
}

// Profesionales disponibles en un link (uno o varios). doctorId es el primario;
// esta tabla guarda el conjunto completo que el paciente puede elegir.
model LinkAgendaProfesional {
  linkId String
  userId String
  link   LinkAgenda @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([linkId, userId])
  @@index([userId])
}

// Ventana semanal recurrente exclusiva de un link (cuando no usa el horario
// del profesional). Ej: día 1 (lunes) 15:00–18:00 = solo evaluaciones online.
model LinkAgendaVentana {
  id         String     @id @default(cuid())
  linkId     String
  diaSemana  Int        // 0=domingo … 6=sábado
  horaInicio String     // "15:00"
  horaFin    String     // "18:00"
  link       LinkAgenda @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
}

// CRM: prospecto captado por formulario web, campaña de Meta, reserva online, etc.
model Lead {
  id            String     @id @default(cuid())
  nombre        String
  apellido      String?
  telefono      String?
  email         String?
  rut           String?
  motivo        String?
  tratamiento   String?    // tratamiento de interés (Implantes, Ortodoncia, etc.)
  piezasReemplazar   String? // dato dental de la campaña (piezas a reemplazar)
  tiempoDesdePerdida String? // hace cuánto perdió la(s) pieza(s)
  estado        String     @default("NUEVO")      // NUEVO | CONTACTADO | AGENDADO | CONVERTIDO | PERDIDO
  origen        String     @default("FORMULARIO")  // FORMULARIO | META | INSTAGRAM | AGENDA_ONLINE | MANUAL | OTRO
  campana       String?
  externalId    String?    // id externo del lead — mejora el Event Match Quality de Meta
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmContent    String?
  utmTerm       String?
  // Click-ids por plataforma (multi-canal)
  fbclid        String?
  ctwaClid      String?    // Click-to-WhatsApp (Meta)
  gclid         String?    // Google Ads
  msclkid       String?    // Microsoft Ads
  ttclid        String?    // TikTok
  twclid        String?    // X / Twitter
  liFatId       String?    // LinkedIn
  igclid        String?    // Instagram
  dclid         String?    // Google Display / DV360
  fbp           String?
  fbc           String?
  referrer      String?
  landing       String?
  tituloPagina  String?
  pantalla      String?    // resolución de pantalla (px)
  locale        String?
  ip            String?
  userAgent     String?
  primeraVisita DateTime?
  ultimaVisita  DateTime?
  fechaAgenda   DateTime?  // fecha/hora de la cita agendada
  agendaFuente  String?    // fuente del agendamiento (link, recepción, etc.)
  asistio       Boolean?   // asistió a la cita (null = desconocido)
  pacienteId    String?    // si se convierte en paciente
  citaId        String?    // si agenda una cita
  responsableId String?    // usuario a cargo del seguimiento
  metaEventId   String?    // id de evento (Lead) para deduplicar con el Pixel del navegador
  metaEnviado   Boolean    @default(false)
  scheduleEventId     String?  // event_id del evento Schedule (dedup con el Pixel)
  scheduleCapiEnviado Boolean @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  notas         LeadNota[]

  @@index([estado, createdAt])
  @@index([origen])
}

// Timeline de un lead: notas manuales y cambios de estado.
model LeadNota {
  id          String   @id @default(cuid())
  leadId      String
  autorId     String?
  autorNombre String?
  tipo        String   @default("NOTA") // NOTA | ESTADO | SISTEMA
  texto       String
  createdAt   DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}
