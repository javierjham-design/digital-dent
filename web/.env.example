# Sitio web / marketing de Cláriva — variables de build (Vite)
# ───────────────────────────────────────────────────────────────────────────

# URL pública del backend (para precios públicos y crear demos), con /api/v1.
#   Dev:        http://localhost:4000/api/v1
#   Producción: https://api.clariva.cl/api/v1
VITE_API_URL=https://api.clariva.cl/api/v1

# Dominio de la plataforma. Se usa para construir los enlaces a la app:
#   - Iniciar sesión → https://app.<dominio>
#   - Demo creada    → https://<slug>.<dominio>/agenda#token=...  (auto-login)
# Dejar vacío en dev: el login apunta a http://localhost:5173 y la demo muestra credenciales.
VITE_PLATFORM_DOMAIN=clariva.cl
