generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// MULTI-TENANCY: cada clínica es un tenant aislado.
// Todos los modelos de datos llevan clinicaId.
// El JWT contiene clinicaId; las queries deben filtrar por él.
// ─────────────────────────────────────────────────────────────

model Clinica {
  id          String   @id @default(cuid())
  slug        String   @unique
  nombre      String
  rut         String?  @unique
  direccion   String   @default("")
  ciudad      String   @default("Temuco")
  telefono    String   @default("")
  email       String   @default("")
  logoUrl     String?
  mensajeWA   String   @default("Hola {nombre}, te escribimos de *{clinica}* para confirmar tu cita el {fecha} en {direccion}.")
  plan        String   @default("TRIAL")
  activo      Boolean  @default(true)
  trialHasta  DateTime?

  // Facturación de la suscripción a la plataforma (gestionado por super-admin).
  // El estado de pago se deriva de proximoCobro/trialHasta/activo (ver lib/billing.ts).
  cicloFacturacion String    @default("MENSUAL") // MENSUAL | ANUAL
  precioAcordado   Float?    // override del precio del plan (negociación particular)
  proximoCobro     DateTime? // siguiente vencimiento; null si TRIAL o sin definir
  notasInternas    String?   // notas privadas del super-admin sobre la cuenta

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  pacientes     Paciente[]
  citas         Cita[]
  prestaciones  Prestacion[]
  tratamientos  Tratamiento[]
  fichas        FichaClinica[]
  presupuestos  Presupuesto[]
  planes        PlanTratamiento[]
  evoluciones   Evolucion[]
  cobros        Cobro[]
  mediosPago    MedioPago[]
  contratos     Contrato[]
  liquidaciones Liquidacion[]
  horarios      HorarioDoctor[]
  comentariosAdmin ComentarioAdministrativo[]
  mensajes         MensajePaciente[]
  pagosSuscripcion PagoSuscripcion[]
  cajas            Caja[]
  movimientosCaja  MovimientoCaja[]
  bloqueosAgenda   BloqueoAgenda[]

  // ─── Integración con Google Calendar (una sola cuenta por clínica) ──────
  // Los tokens van cifrados (AES-256-GCM con ENCRYPTION_KEY del entorno).
  googleRefreshToken   String?
  googleAccessToken    String?
  googleTokenExpiresAt DateTime?
  googleAccountEmail   String?       // email de la cuenta Google conectada (visual)
  googleConnectedAt    DateTime?
  googleConnectedById  String?
  googleConnectedByName String?

  // ─── Confirmaciones automáticas por WhatsApp (vía Twilio) ───────────────
  // Servicio extra de pago, habilitado por el super-admin por clínica.
  // El auth token de Twilio va cifrado (AES-256-GCM con ENCRYPTION_KEY).
  waEnabled      Boolean @default(false)
  waTwilioSid    String?   // Account SID o subcuenta de Twilio
  waTwilioToken  String?   // Auth token, CIFRADO
  waNumero       String?   // número emisor en formato E.164 (+56912345678)
  waTemplateSid  String?   // Content SID de la plantilla aprobada (HX...)
  waHorasAntes   Int     @default(24) // cuántas horas antes de la cita se envía

  extras ExtraSuscripcion[]
}

// Cargo adicional recurrente sobre el plan de una clínica (ej: módulo de
// confirmaciones WhatsApp, número adicional). Los extras ACTIVOS se suman al
// precio mensual del plan en el MRR, el resumen y el monto sugerido de pago.
model ExtraSuscripcion {
  id           String   @id @default(cuid())
  clinicaId    String
  codigo       String   @default("OTRO") // WHATSAPP | OTRO (referencia interna)
  nombre       String                    // "Confirmaciones WhatsApp"
  montoMensual Float
  activo       Boolean  @default(true)
  notas        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clinica      Clinica  @relation(fields: [clinicaId], references: [id])

  @@index([clinicaId])
}

// Catálogo de planes de suscripción que la plataforma ofrece a las clínicas.
// El "id" es el código corto (TRIAL, BASICO, PRO, ENTERPRISE...) y coincide
// con el valor de Clinica.plan. Editable desde el super-admin.
model PlanSuscripcion {
  id              String   @id                    // código corto en mayúsculas
  nombre          String                          // nombre comercial
  descripcion     String?
  precioMensual   Float    @default(0)            // CLP/mes (0 = gratis / trial)
  precioAnual     Float?                          // CLP/año (opcional; si null se asume mensual * 12)
  caracteristicas String   @default("[]")         // JSON: string[] con bullets descriptivos
  destacado       Boolean  @default(false)        // marcar como "más popular" en la grilla
  orden           Int      @default(0)            // orden de presentación
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Pago de suscripción que recibe la plataforma desde una clínica.
// Registro manual hasta que exista pasarela (Fase 4): el super-admin marca
// la transferencia/depósito recibido, y la plataforma recalcula próximoCobro.
model PagoSuscripcion {
  id            String   @id @default(cuid())
  clinicaId     String
  fechaPago     DateTime @default(now())
  monto         Float
  periodoDesde  DateTime
  periodoHasta  DateTime
  metodoPago    String   // TRANSFERENCIA | WEBPAY | EFECTIVO | OTRO
  comprobante   String?  // referencia, número de op, o URL del recibo
  notas         String?
  registradoPor String?  // user id del super-admin que registró el pago
  createdAt     DateTime @default(now())
  clinica       Clinica  @relation(fields: [clinicaId], references: [id])

  @@index([clinicaId, fechaPago])
}

// LEGACY: se mantiene durante la migración a multi-tenant.
// Sus datos se copian a Clinica en el seed; eliminar este modelo
// en una segunda fase una vez verificada la migración en producción.
model Configuracion {
  id        String  @id @default("singleton")
  clinica   String  @default("Digital-Dent")
  direccion String  @default("")
  telefono  String  @default("")
  email     String  @default("")
  ciudad    String  @default("Temuco")
  mensajeWA String  @default("Hola {nombre}, te escribimos de *{clinica}* para confirmar tu cita el {fecha} en {direccion}.")
  logoUrl   String?
}

model User {
  id            String    @id @default(cuid())
  clinicaId     String?   // null para super-admins de la plataforma
  name          String?
  email         String?   @unique
  username      String?   // login interno por clínica (sin email)
  password      String
  role          String    @default("staff") // admin, doctor, staff
  rut           String?   @unique
  especialidad  String?
  telefono      String?
  activo        Boolean   @default(true)
  isPlatformAdmin   Boolean   @default(false)   // super-admin que gestiona TODAS las clínicas
  passwordChangedAt DateTime?                   // null = nunca cambió la default → forzar cambio en primer login
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  puedeRecibirPagos Boolean   @default(false)
  puedeModificarPrecio  Boolean @default(false)
  puedeAplicarDescuento Boolean @default(false)
  puedeRevertirCompletado Boolean @default(false)
  puedeEditarPagos  Boolean   @default(false)   // editar y anular cobros ya emitidos
  puedeGestionarLiquidaciones Boolean @default(false) // crear/aprobar/pagar liquidaciones de cualquier doctor
  clinica       Clinica?       @relation(fields: [clinicaId], references: [id])
  sessions      Session[]
  citas         Cita[]         @relation("DoctorCitas")
  tratamientos  Tratamiento[]  @relation("DoctorTratamientos")
  contratos     Contrato[]
  liquidaciones Liquidacion[]
  horarios      HorarioDoctor[]
  cobrosRecibidos Cobro[]      @relation("CobroUsuario")
  evolucionesCreadas Evolucion[] @relation("AutorEvolucion")
  planesTitulares PlanTratamiento[] @relation("DoctorTitularPlanes")
  cajas            CajaUsuario[]
  movimientosCaja  MovimientoCaja[] @relation("MovimientoUsuario")
  bloqueosAgenda   BloqueoAgenda[]  @relation("DoctorBloqueos")
  // ID del Google Calendar (dentro de la cuenta de la clínica) al que se
  // sincroniza la agenda de este doctor. Lo asigna el admin desde /usuarios.
  googleCalendarId String?
  // Token incremental para pull (events.list?syncToken=...). Cuando es null
  // el próximo sync hace un full snapshot (e.g. tras mapear el calendario
  // por primera vez o tras un 410 Gone de Google).
  googleSyncToken  String?
  googleSyncedAt   DateTime?

  @@unique([clinicaId, username])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Paciente {
  id              String    @id @default(cuid())
  clinicaId       String?
  numero          Int?      // correlativo por clínica (1, 2, 3...)
  rut             String?
  otroDocId       String?   // pasaporte / DNI extranjero
  nombre          String
  apellido        String
  nombreSocial    String?
  fechaNacimiento DateTime?
  genero          String?
  sexo            String?
  nacionalidad    String?
  migrante        String?   // "Sí" | "No" | null
  puebloOriginario String?
  telefono        String?   // móvil
  telefonoFijo    String?
  email           String?
  direccion       String?
  ciudad          String?
  comuna          String?
  prevision       String?
  actividad       String?   // profesión / actividad
  empleador       String?
  apoderado       String?
  rutApoderado    String?
  referencia      String?
  tipoPaciente    String?   // categoría libre (ej: VIP, Habitual, etc.)
  numeroInterno   String?   // # interno opcional de la clínica
  alergias        String?
  antecedentes    String?
  observaciones   String?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clinica         Clinica?      @relation(fields: [clinicaId], references: [id])
  citas           Cita[]
  fichaClinica    FichaClinica?
  presupuestos    Presupuesto[]
  planes          PlanTratamiento[]
  evoluciones     Evolucion[]
  cobros          Cobro[]
  comentariosAdmin ComentarioAdministrativo[]
  mensajes         MensajePaciente[]

  @@unique([clinicaId, rut])
  @@unique([clinicaId, numero])
}

model ComentarioAdministrativo {
  id          String   @id @default(cuid())
  clinicaId   String?
  pacienteId  String
  autorNombre String
  autorId     String?
  texto       String
  createdAt   DateTime @default(now())
  paciente    Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  clinica     Clinica? @relation(fields: [clinicaId], references: [id])
}

model MensajePaciente {
  id          String   @id @default(cuid())
  clinicaId   String?
  pacienteId  String
  citaId      String?
  tipo        String   // EMAIL | WHATSAPP | SMS
  categoria   String   // CONFIRMACION_CITA | PLAN_TRATAMIENTO | DOCUMENTO | RECETA | OTRO
  asunto      String?
  cuerpo      String?
  enviadoA    String?
  estado      String   @default("ENVIADO") // ENVIADO | ENTREGADO | LEIDO | FALLIDO
  createdAt   DateTime @default(now())
  paciente    Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  clinica     Clinica? @relation(fields: [clinicaId], references: [id])
  cita        Cita?    @relation(fields: [citaId], references: [id])
}

model Cita {
  id            String    @id @default(cuid())
  clinicaId     String?
  pacienteId    String
  doctorId      String
  fecha         DateTime
  duracion      Int       @default(30)
  estado        String    @default("PENDIENTE")
  tipo          String?
  notas         String?
  sala          String?
  sobrecupo     Boolean   @default(false)   // si true, va a la agenda paralela de Sobre Agendamiento
  confirmadoWA  Boolean   @default(false)
  // Sincronización con Google Calendar (Fase 2). googleEventId vacío =
  // todavía no sincronizada. googleSyncError = última falla al pushear.
  googleEventId   String?
  googleSyncedAt  DateTime?
  googleSyncError String?
  // SID del mensaje de WhatsApp de recordatorio enviado vía Twilio.
  // null = todavía no se envió. Evita doble envío y permite correlacionar
  // la respuesta del paciente con esta cita.
  waMessageSid    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clinica       Clinica?  @relation(fields: [clinicaId], references: [id])
  paciente      Paciente  @relation(fields: [pacienteId], references: [id])
  doctor        User      @relation("DoctorCitas", fields: [doctorId], references: [id])
  logs          CitaLog[]
  mensajes      MensajePaciente[]

  @@index([googleEventId])
  @@index([waMessageSid])
}

model CitaLog {
  id        String   @id @default(cuid())
  citaId    String
  tipo      String   // AGENDADA | ESTADO | WA_ENVIADO
  detalle   String
  userName  String   @default("Sistema")
  createdAt DateTime @default(now())
  cita      Cita     @relation(fields: [citaId], references: [id], onDelete: Cascade)
}

model FichaClinica {
  id              String        @id @default(cuid())
  clinicaId       String?
  pacienteId      String        @unique
  grupoSanguineo  String?
  fumador         Boolean       @default(false)
  embarazada      Boolean       @default(false)
  diabetico       Boolean       @default(false)
  hipertenso      Boolean       @default(false)
  cardiopatia     Boolean       @default(false)
  medicamentos    String?
  notasClinicas   String?
  alertasMedicas    String?
  enfermedadesNotas String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  clinica         Clinica?      @relation(fields: [clinicaId], references: [id])
  paciente        Paciente      @relation(fields: [pacienteId], references: [id])
  tratamientos    Tratamiento[]
  odontograma     Diente[]
}

model Diente {
  id             String        @id @default(cuid())
  fichaId        String
  numero         Int
  cara           String?
  estado         String        @default("SANO")
  color          String?
  notas          String?
  ficha          FichaClinica  @relation(fields: [fichaId], references: [id])

  @@unique([fichaId, numero, cara])
}

model Prestacion {
  id               String            @id @default(cuid())
  clinicaId        String?
  nombre           String
  descripcion      String?
  precio           Float
  duracion         Int               @default(30)
  categoria        String?
  activo           Boolean           @default(true)
  clinica          Clinica?          @relation(fields: [clinicaId], references: [id])
  tratamientos     Tratamiento[]
  itemsPresupuesto ItemPresupuesto[]
}

model Tratamiento {
  id           String       @id @default(cuid())
  clinicaId    String?
  fichaId      String
  planId       String?
  seccionId    String?
  prestacionId String
  doctorId     String?
  diente       Int?
  cara         String?
  estado       String       @default("PLANIFICADO")
  precio       Float
  descuento    Float        @default(0) // porcentaje 0-100, se aplica sobre `precio`
  notas        String?
  fecha        DateTime     @default(now())
  fechaCompletado DateTime?
  clinica      Clinica?        @relation(fields: [clinicaId], references: [id])
  ficha        FichaClinica    @relation(fields: [fichaId], references: [id])
  plan         PlanTratamiento? @relation(fields: [planId], references: [id], onDelete: SetNull)
  seccion      SeccionPlan?    @relation(fields: [seccionId], references: [id], onDelete: SetNull)
  prestacion   Prestacion      @relation(fields: [prestacionId], references: [id])
  doctor       User?           @relation("DoctorTratamientos", fields: [doctorId], references: [id])
  liquidacionItems LiquidacionItem[]
  cobroItems   CobroItem[]
  evoluciones  Evolucion[]
}

model PlanTratamiento {
  id              String         @id @default(cuid())
  clinicaId       String?
  pacienteId      String
  doctorTitularId String?        // doctor responsable del plan; default para nuevas acciones
  nombre          String         @default("Plan de tratamiento")
  estado          String         @default("ACTIVO")  // ACTIVO | ARCHIVADO | COMPLETADO
  notas           String?
  fechaInicio     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  clinica         Clinica?       @relation(fields: [clinicaId], references: [id])
  paciente        Paciente       @relation(fields: [pacienteId], references: [id])
  doctorTitular   User?          @relation("DoctorTitularPlanes", fields: [doctorTitularId], references: [id])
  secciones       SeccionPlan[]
  tratamientos    Tratamiento[]
}

model SeccionPlan {
  id              String           @id @default(cuid())
  planId          String
  titulo          String           @default("Sección")
  orden           Int              @default(0)
  fechaTentativa  DateTime?
  diasDesdeAnterior Int?           // espera tentativa desde la sección previa (ej. 90 días)
  notas           String?
  plan            PlanTratamiento  @relation(fields: [planId], references: [id], onDelete: Cascade)
  tratamientos    Tratamiento[]
}

model Evolucion {
  id            String       @id @default(cuid())
  clinicaId     String?
  pacienteId    String
  tratamientoId String?      // si la evolución corresponde a una acción específica
  autorId       String?
  texto         String
  createdAt     DateTime     @default(now())
  clinica       Clinica?     @relation(fields: [clinicaId], references: [id])
  paciente      Paciente     @relation(fields: [pacienteId], references: [id])
  tratamiento   Tratamiento? @relation(fields: [tratamientoId], references: [id], onDelete: SetNull)
  autor         User?        @relation("AutorEvolucion", fields: [autorId], references: [id])
}

model Presupuesto {
  id           String            @id @default(cuid())
  clinicaId    String?
  pacienteId   String
  numero       Int
  estado       String            @default("PENDIENTE")
  total        Float             @default(0)
  notas        String?
  vigencia     DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  clinica      Clinica?          @relation(fields: [clinicaId], references: [id])
  paciente     Paciente          @relation(fields: [pacienteId], references: [id])
  items        ItemPresupuesto[]

  @@unique([clinicaId, numero])
}

model ItemPresupuesto {
  id             String      @id @default(cuid())
  presupuestoId  String
  prestacionId   String
  diente         Int?
  cantidad       Int         @default(1)
  precioUnitario Float
  descuento      Float       @default(0)
  subtotal       Float
  presupuesto    Presupuesto @relation(fields: [presupuestoId], references: [id])
  prestacion     Prestacion  @relation(fields: [prestacionId], references: [id])
}

model MedioPago {
  id        String   @id @default(cuid())
  clinicaId String?
  nombre    String
  comision  Float    @default(0)
  activo    Boolean  @default(true)
  clinica   Clinica? @relation(fields: [clinicaId], references: [id])
  cobros    Cobro[]
}

model Cobro {
  id              String     @id @default(cuid())
  clinicaId       String?
  pacienteId      String
  numero          Int
  concepto        String
  monto           Float
  montoNeto       Float?
  comisionMonto   Float?
  estado          String     @default("PENDIENTE")
  medioPagoId     String?
  metodoPago      String?
  reciboUsuarioId String?
  cajaId          String?    // caja a la que se asoció el ingreso
  fechaPago       DateTime?
  notas           String?
  // Anulación: si anulado=true, el cobro queda registrado para auditoría
  anulado         Boolean    @default(false)
  motivoAnulacion String?
  anuladoAt       DateTime?
  anuladoPorId    String?
  anuladoPorNombre String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  clinica         Clinica?   @relation(fields: [clinicaId], references: [id])
  paciente        Paciente   @relation(fields: [pacienteId], references: [id])
  medioPago       MedioPago? @relation(fields: [medioPagoId], references: [id])
  reciboUsuario   User?      @relation("CobroUsuario", fields: [reciboUsuarioId], references: [id])
  caja            Caja?      @relation(fields: [cajaId], references: [id])
  items           CobroItem[]
  movimientos     MovimientoCaja[]

  @@unique([clinicaId, numero])
}

// ─────────────────────────────────────────────────────────────
// CAJA: registro de ingresos y egresos (flujo de efectivo) por clínica.
// Cada caja puede tener uno o más usuarios autorizados a operarla.
// Los ingresos vienen de Cobros; los egresos se registran manualmente.
// ─────────────────────────────────────────────────────────────
model Caja {
  id            String    @id @default(cuid())
  clinicaId     String
  nombre        String
  descripcion   String?
  saldoInicial  Float     @default(0)
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clinica       Clinica   @relation(fields: [clinicaId], references: [id])
  usuarios      CajaUsuario[]
  movimientos   MovimientoCaja[]
  cobros        Cobro[]
  sesiones      SesionCaja[]

  @@unique([clinicaId, nombre])
}

// Sesión de caja (período abierto/cerrado).
// Una caja puede tener varias sesiones cronológicamente. Solo una está ABIERTA a la vez.
// Al cerrar se hace cuadre: el sistema calcula el saldo esperado y el usuario ingresa
// el conteo real → diferencia. Cada movimiento queda asociado a su sesión.
model SesionCaja {
  id              String    @id @default(cuid())
  clinicaId       String
  cajaId          String
  estado          String    @default("ABIERTA")  // ABIERTA | CERRADA
  saldoApertura   Float     @default(0)          // snapshot del saldo de la caja al abrir esta sesión
  abiertaPorId    String
  abiertaPorNombre String?
  abiertaAt       DateTime  @default(now())
  cerradaPorId    String?
  cerradaPorNombre String?
  cerradaAt       DateTime?
  // Cuadre al cierre
  saldoEsperado   Float?    // saldoApertura + ingresos - egresos del período
  saldoReal       Float?    // conteo declarado por el usuario
  diferencia      Float?    // saldoReal - saldoEsperado
  totalIngresos   Float?
  totalEgresos    Float?
  observaciones   String?
  createdAt       DateTime  @default(now())
  caja            Caja      @relation(fields: [cajaId], references: [id])
  movimientos     MovimientoCaja[]

  @@index([cajaId, estado])
  @@index([cajaId, abiertaAt])
}

model CajaUsuario {
  cajaId String
  userId String
  caja   Caja   @relation(fields: [cajaId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cajaId, userId])
}

model MovimientoCaja {
  id              String   @id @default(cuid())
  clinicaId       String
  cajaId          String
  sesionCajaId    String?  // sesión a la que pertenece (nullable para movs legacy)
  tipo            String   // INGRESO | EGRESO
  monto           Float
  descripcion     String
  categoria       String?  // EGRESO: ARRIENDO, INSUMOS, SUELDO, RETIRO, OTRO. INGRESO: COBRO, OTRO.
  fecha           DateTime @default(now())
  cobroId         String?  // si el movimiento es ingreso por un cobro
  userId          String   // quien registra el movimiento
  anulado         Boolean  @default(false)
  motivoAnulacion String?
  anuladoAt       DateTime?
  anuladoPorId    String?
  anuladoPorNombre String?
  createdAt       DateTime @default(now())
  caja            Caja     @relation(fields: [cajaId], references: [id])
  cobro           Cobro?   @relation(fields: [cobroId], references: [id])
  user            User     @relation("MovimientoUsuario", fields: [userId], references: [id])
  clinica         Clinica  @relation(fields: [clinicaId], references: [id])
  sesion          SesionCaja? @relation(fields: [sesionCajaId], references: [id])

  @@index([clinicaId, cajaId, fecha])
  @@index([sesionCajaId])
}

model CobroItem {
  id            String       @id @default(cuid())
  cobroId       String
  tratamientoId String?
  descripcion   String
  monto         Float
  cobro         Cobro        @relation(fields: [cobroId], references: [id], onDelete: Cascade)
  tratamiento   Tratamiento? @relation(fields: [tratamientoId], references: [id])
}

model Contrato {
  id           String        @id @default(cuid())
  clinicaId    String?
  doctorId     String
  tipo         String        // PORCENTAJE | MONTO_FIJO
  porcentaje   Float?
  montoFijo    Float?
  descripcion  String?
  fechaInicio  DateTime      @default(now())
  fechaFin     DateTime?
  activo       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  clinica      Clinica?      @relation(fields: [clinicaId], references: [id])
  doctor       User          @relation(fields: [doctorId], references: [id])
  liquidaciones Liquidacion[]
}

model Liquidacion {
  id             String            @id @default(cuid())
  clinicaId      String?
  doctorId       String
  contratoId     String
  periodo        String            // YYYY-MM
  totalBruto     Float             @default(0)
  totalLiquidado Float             @default(0)
  estado         String            @default("BORRADOR") // BORRADOR | APROBADA | PAGADA
  notas          String?
  fechaPago      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  clinica        Clinica?          @relation(fields: [clinicaId], references: [id])
  doctor         User              @relation(fields: [doctorId], references: [id])
  contrato       Contrato          @relation(fields: [contratoId], references: [id])
  items          LiquidacionItem[]
}

model LiquidacionItem {
  id                 String      @id @default(cuid())
  liquidacionId      String
  tratamientoId      String
  prestacionNombre   String
  pacienteNombre     String
  diente             String?
  fechaCompletado    DateTime
  precioTratamiento  Float
  porcentajeAplicado Float?
  montoFijoAplicado  Float?
  montoLiquidado     Float
  liquidacion        Liquidacion  @relation(fields: [liquidacionId], references: [id])
  tratamiento        Tratamiento  @relation(fields: [tratamientoId], references: [id])
}

model HorarioDoctor {
  id              String   @id @default(cuid())
  clinicaId       String?
  doctorId        String
  diaSemana       Int      // 0=Dom 1=Lun 2=Mar 3=Mié 4=Jue 5=Vie 6=Sáb
  horaInicio      String
  horaFin         String
  activo          Boolean  @default(true)
  // Receso (bloque sin agenda, ej. almuerzo). Opcional.
  recesoActivo    Boolean  @default(false)
  recesoInicio    String?
  recesoFin       String?
  // Sobrecupos: agenda paralela para casos excepcionales (overbooking)
  sobrecupoActivo Boolean  @default(false)
  sobrecupoInicio String?
  sobrecupoFin    String?
  clinica         Clinica? @relation(fields: [clinicaId], references: [id])
  doctor          User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, diaSemana])
}

// Bloqueo de un rango horario en la agenda de un doctor.
// Sirve para: vacaciones, capacitaciones, ausencias, almuerzos extra, etc.
// Cuando llegue la integración con Google Calendar, los eventos sin paciente
// identificable (creados directamente en Google) se materializan acá.
model BloqueoAgenda {
  id            String   @id @default(cuid())
  clinicaId     String
  doctorId      String
  inicio        DateTime
  fin           DateTime
  motivo        String?
  createdById   String?
  createdByName String?
  // Sincronización con Google Calendar (poblado en la fase 2).
  googleEventId   String?
  googleSyncedAt  DateTime?
  googleSyncError String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  clinica       Clinica  @relation(fields: [clinicaId], references: [id])
  doctor        User     @relation("DoctorBloqueos", fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([clinicaId, doctorId, inicio])
  @@index([googleEventId])
}

// Bitácora de acciones sensibles del super-admin (reset password, cambio de
// plan, suspensión, registro de pago manual, extensión de trial). Se escribe
// best-effort en cada endpoint admin/* — si falla la escritura del log NO
// rompe la operación primaria, solo se loguea por consola.
model AuditLogAdmin {
  id           String   @id @default(cuid())
  actorId      String   // User.id del super-admin
  actorEmail   String   // copia plana (en caso de que el user se elimine)
  action       String   // RESET_PASSWORD | CAMBIAR_PLAN | CAMBIAR_ESTADO | EXTENDER_TRIAL | REGISTRAR_PAGO | ELIMINAR_PAGO | CREAR_CLINICA
  targetType   String   // CLINICA | USUARIO | PAGO | PLAN
  targetId     String?  // id del recurso afectado (clinica, pago, etc.)
  details      String?  // JSON serializado con contexto adicional (montos, fechas, etc.)
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
}
