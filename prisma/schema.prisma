generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// MULTI-TENANCY: cada clínica es un tenant aislado.
// Todos los modelos de datos llevan clinicaId.
// El JWT contiene clinicaId; las queries deben filtrar por él.
// ─────────────────────────────────────────────────────────────

model Clinica {
  id          String   @id @default(cuid())
  slug        String   @unique
  nombre      String
  rut         String?  @unique
  direccion   String   @default("")
  ciudad      String   @default("Temuco")
  telefono    String   @default("")
  email       String   @default("")
  logoUrl     String?
  mensajeWA   String   @default("Hola {nombre}, te escribimos de *{clinica}* para confirmar tu cita el {fecha} en {direccion}.")
  plan        String   @default("TRIAL")
  activo      Boolean  @default(true)
  trialHasta  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  pacientes     Paciente[]
  citas         Cita[]
  prestaciones  Prestacion[]
  tratamientos  Tratamiento[]
  fichas        FichaClinica[]
  presupuestos  Presupuesto[]
  cobros        Cobro[]
  mediosPago    MedioPago[]
  contratos     Contrato[]
  liquidaciones Liquidacion[]
  horarios      HorarioDoctor[]
  comentariosAdmin ComentarioAdministrativo[]
  mensajes         MensajePaciente[]
}

// LEGACY: se mantiene durante la migración a multi-tenant.
// Sus datos se copian a Clinica en el seed; eliminar este modelo
// en una segunda fase una vez verificada la migración en producción.
model Configuracion {
  id        String  @id @default("singleton")
  clinica   String  @default("Digital-Dent")
  direccion String  @default("")
  telefono  String  @default("")
  email     String  @default("")
  ciudad    String  @default("Temuco")
  mensajeWA String  @default("Hola {nombre}, te escribimos de *{clinica}* para confirmar tu cita el {fecha} en {direccion}.")
  logoUrl   String?
}

model User {
  id            String    @id @default(cuid())
  clinicaId     String?   // null para super-admins de la plataforma
  name          String?
  email         String?   @unique
  username      String?   // login interno por clínica (sin email)
  password      String
  role          String    @default("staff") // admin, doctor, staff
  rut           String?   @unique
  especialidad  String?
  telefono      String?
  activo        Boolean   @default(true)
  isPlatformAdmin   Boolean   @default(false)   // super-admin que gestiona TODAS las clínicas
  passwordChangedAt DateTime?                   // null = nunca cambió la default → forzar cambio en primer login
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  puedeRecibirPagos Boolean   @default(false)
  clinica       Clinica?       @relation(fields: [clinicaId], references: [id])
  sessions      Session[]
  citas         Cita[]         @relation("DoctorCitas")
  tratamientos  Tratamiento[]  @relation("DoctorTratamientos")
  contratos     Contrato[]
  liquidaciones Liquidacion[]
  horarios      HorarioDoctor[]
  cobrosRecibidos Cobro[]      @relation("CobroUsuario")

  @@unique([clinicaId, username])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Paciente {
  id              String    @id @default(cuid())
  clinicaId       String?
  numero          Int?      // correlativo por clínica (1, 2, 3...)
  rut             String?
  otroDocId       String?   // pasaporte / DNI extranjero
  nombre          String
  apellido        String
  nombreSocial    String?
  fechaNacimiento DateTime?
  genero          String?
  sexo            String?
  nacionalidad    String?
  migrante        String?   // "Sí" | "No" | null
  puebloOriginario String?
  telefono        String?   // móvil
  telefonoFijo    String?
  email           String?
  direccion       String?
  ciudad          String?
  comuna          String?
  prevision       String?
  actividad       String?   // profesión / actividad
  empleador       String?
  apoderado       String?
  rutApoderado    String?
  referencia      String?
  tipoPaciente    String?   // categoría libre (ej: VIP, Habitual, etc.)
  numeroInterno   String?   // # interno opcional de la clínica
  alergias        String?
  antecedentes    String?
  observaciones   String?
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clinica         Clinica?      @relation(fields: [clinicaId], references: [id])
  citas           Cita[]
  fichaClinica    FichaClinica?
  presupuestos    Presupuesto[]
  cobros          Cobro[]
  comentariosAdmin ComentarioAdministrativo[]
  mensajes         MensajePaciente[]

  @@unique([clinicaId, rut])
  @@unique([clinicaId, numero])
}

model ComentarioAdministrativo {
  id          String   @id @default(cuid())
  clinicaId   String?
  pacienteId  String
  autorNombre String
  autorId     String?
  texto       String
  createdAt   DateTime @default(now())
  paciente    Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  clinica     Clinica? @relation(fields: [clinicaId], references: [id])
}

model MensajePaciente {
  id          String   @id @default(cuid())
  clinicaId   String?
  pacienteId  String
  citaId      String?
  tipo        String   // EMAIL | WHATSAPP | SMS
  categoria   String   // CONFIRMACION_CITA | PLAN_TRATAMIENTO | DOCUMENTO | RECETA | OTRO
  asunto      String?
  cuerpo      String?
  enviadoA    String?
  estado      String   @default("ENVIADO") // ENVIADO | ENTREGADO | LEIDO | FALLIDO
  createdAt   DateTime @default(now())
  paciente    Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  clinica     Clinica? @relation(fields: [clinicaId], references: [id])
  cita        Cita?    @relation(fields: [citaId], references: [id])
}

model Cita {
  id            String    @id @default(cuid())
  clinicaId     String?
  pacienteId    String
  doctorId      String
  fecha         DateTime
  duracion      Int       @default(30)
  estado        String    @default("PENDIENTE")
  tipo          String?
  notas         String?
  sala          String?
  confirmadoWA  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clinica       Clinica?  @relation(fields: [clinicaId], references: [id])
  paciente      Paciente  @relation(fields: [pacienteId], references: [id])
  doctor        User      @relation("DoctorCitas", fields: [doctorId], references: [id])
  logs          CitaLog[]
  mensajes      MensajePaciente[]
}

model CitaLog {
  id        String   @id @default(cuid())
  citaId    String
  tipo      String   // AGENDADA | ESTADO | WA_ENVIADO
  detalle   String
  userName  String   @default("Sistema")
  createdAt DateTime @default(now())
  cita      Cita     @relation(fields: [citaId], references: [id], onDelete: Cascade)
}

model FichaClinica {
  id              String        @id @default(cuid())
  clinicaId       String?
  pacienteId      String        @unique
  grupoSanguineo  String?
  fumador         Boolean       @default(false)
  embarazada      Boolean       @default(false)
  diabetico       Boolean       @default(false)
  hipertenso      Boolean       @default(false)
  cardiopatia     Boolean       @default(false)
  medicamentos    String?
  notasClinicas   String?
  alertasMedicas    String?
  enfermedadesNotas String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  clinica         Clinica?      @relation(fields: [clinicaId], references: [id])
  paciente        Paciente      @relation(fields: [pacienteId], references: [id])
  tratamientos    Tratamiento[]
  odontograma     Diente[]
}

model Diente {
  id             String        @id @default(cuid())
  fichaId        String
  numero         Int
  cara           String?
  estado         String        @default("SANO")
  color          String?
  notas          String?
  ficha          FichaClinica  @relation(fields: [fichaId], references: [id])

  @@unique([fichaId, numero, cara])
}

model Prestacion {
  id               String            @id @default(cuid())
  clinicaId        String?
  nombre           String
  descripcion      String?
  precio           Float
  duracion         Int               @default(30)
  categoria        String?
  activo           Boolean           @default(true)
  clinica          Clinica?          @relation(fields: [clinicaId], references: [id])
  tratamientos     Tratamiento[]
  itemsPresupuesto ItemPresupuesto[]
}

model Tratamiento {
  id           String       @id @default(cuid())
  clinicaId    String?
  fichaId      String
  prestacionId String
  doctorId     String?
  diente       Int?
  cara         String?
  estado       String       @default("PLANIFICADO")
  precio       Float
  notas        String?
  fecha        DateTime     @default(now())
  fechaCompletado DateTime?
  clinica      Clinica?        @relation(fields: [clinicaId], references: [id])
  ficha        FichaClinica    @relation(fields: [fichaId], references: [id])
  prestacion   Prestacion      @relation(fields: [prestacionId], references: [id])
  doctor       User?           @relation("DoctorTratamientos", fields: [doctorId], references: [id])
  liquidacionItems LiquidacionItem[]
  cobroItems   CobroItem[]
}

model Presupuesto {
  id           String            @id @default(cuid())
  clinicaId    String?
  pacienteId   String
  numero       Int
  estado       String            @default("PENDIENTE")
  total        Float             @default(0)
  notas        String?
  vigencia     DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  clinica      Clinica?          @relation(fields: [clinicaId], references: [id])
  paciente     Paciente          @relation(fields: [pacienteId], references: [id])
  items        ItemPresupuesto[]

  @@unique([clinicaId, numero])
}

model ItemPresupuesto {
  id             String      @id @default(cuid())
  presupuestoId  String
  prestacionId   String
  diente         Int?
  cantidad       Int         @default(1)
  precioUnitario Float
  descuento      Float       @default(0)
  subtotal       Float
  presupuesto    Presupuesto @relation(fields: [presupuestoId], references: [id])
  prestacion     Prestacion  @relation(fields: [prestacionId], references: [id])
}

model MedioPago {
  id        String   @id @default(cuid())
  clinicaId String?
  nombre    String
  comision  Float    @default(0)
  activo    Boolean  @default(true)
  clinica   Clinica? @relation(fields: [clinicaId], references: [id])
  cobros    Cobro[]
}

model Cobro {
  id              String     @id @default(cuid())
  clinicaId       String?
  pacienteId      String
  numero          Int
  concepto        String
  monto           Float
  montoNeto       Float?
  comisionMonto   Float?
  estado          String     @default("PENDIENTE")
  medioPagoId     String?
  metodoPago      String?
  reciboUsuarioId String?
  fechaPago       DateTime?
  notas           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  clinica         Clinica?   @relation(fields: [clinicaId], references: [id])
  paciente        Paciente   @relation(fields: [pacienteId], references: [id])
  medioPago       MedioPago? @relation(fields: [medioPagoId], references: [id])
  reciboUsuario   User?      @relation("CobroUsuario", fields: [reciboUsuarioId], references: [id])
  items           CobroItem[]

  @@unique([clinicaId, numero])
}

model CobroItem {
  id            String       @id @default(cuid())
  cobroId       String
  tratamientoId String?
  descripcion   String
  monto         Float
  cobro         Cobro        @relation(fields: [cobroId], references: [id], onDelete: Cascade)
  tratamiento   Tratamiento? @relation(fields: [tratamientoId], references: [id])
}

model Contrato {
  id           String        @id @default(cuid())
  clinicaId    String?
  doctorId     String
  tipo         String        // PORCENTAJE | MONTO_FIJO
  porcentaje   Float?
  montoFijo    Float?
  descripcion  String?
  fechaInicio  DateTime      @default(now())
  fechaFin     DateTime?
  activo       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  clinica      Clinica?      @relation(fields: [clinicaId], references: [id])
  doctor       User          @relation(fields: [doctorId], references: [id])
  liquidaciones Liquidacion[]
}

model Liquidacion {
  id             String            @id @default(cuid())
  clinicaId      String?
  doctorId       String
  contratoId     String
  periodo        String            // YYYY-MM
  totalBruto     Float             @default(0)
  totalLiquidado Float             @default(0)
  estado         String            @default("BORRADOR") // BORRADOR | APROBADA | PAGADA
  notas          String?
  fechaPago      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  clinica        Clinica?          @relation(fields: [clinicaId], references: [id])
  doctor         User              @relation(fields: [doctorId], references: [id])
  contrato       Contrato          @relation(fields: [contratoId], references: [id])
  items          LiquidacionItem[]
}

model LiquidacionItem {
  id                 String      @id @default(cuid())
  liquidacionId      String
  tratamientoId      String
  prestacionNombre   String
  pacienteNombre     String
  diente             String?
  fechaCompletado    DateTime
  precioTratamiento  Float
  porcentajeAplicado Float?
  montoFijoAplicado  Float?
  montoLiquidado     Float
  liquidacion        Liquidacion  @relation(fields: [liquidacionId], references: [id])
  tratamiento        Tratamiento  @relation(fields: [tratamientoId], references: [id])
}

model HorarioDoctor {
  id         String  @id @default(cuid())
  clinicaId  String?
  doctorId   String
  diaSemana  Int     // 0=Dom 1=Lun 2=Mar 3=Mié 4=Jue 5=Vie 6=Sáb
  horaInicio String
  horaFin    String
  activo     Boolean @default(true)
  clinica    Clinica? @relation(fields: [clinicaId], references: [id])
  doctor     User    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, diaSemana])
}
